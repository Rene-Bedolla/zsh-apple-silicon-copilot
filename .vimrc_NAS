" ═══════════════════════════════════════════════════════════
" .vimrc - SYNOLOGY NAS DS223
" Basado en configuración personal de René López
" Adaptado para DSM 7.3.2 / vim 8.2 (sin Node.js, sin scoop)
" ═══════════════════════════════════════════════════════════

" ─── CRÍTICO: debe ser la primera línea operativa ──────────
set nocompatible        " Ignora incompatibilidad con VI clásico

" ═══════════════════════════════════════════════════════════
" COLORES Y TERMINAL
" Fix crítico para Gruvbox en sesiones SSH:
"   t_Co=256    → habilita 256 colores en terminal remota
"   background  → fuerza fondo oscuro explícitamente
" Estas líneas deben ir ANTES de plug#end() y colorscheme
" ═══════════════════════════════════════════════════════════
set t_Co=256
set background=dark

" ═══════════════════════════════════════════════════════════
" PLUGINS (vim-plug)
" Instalados en ~/.vim/plugged (ruta Unix estándar)
" Omitidos vs Windows:
"   coc.nvim          → requiere Node.js compatible
"   vim-tmux-navigator → requiere tmux
"   fzf               → no instalado en NAS
" ═══════════════════════════════════════════════════════════
call plug#begin('~/.vim/plugged')

" ─── Tema ──────────────────────────────────────────────────
Plug 'morhetz/gruvbox'

" ─── Navegación rápida por el texto ────────────────────────
Plug 'easymotion/vim-easymotion'

" ─── Árbol de directorios lateral ──────────────────────────
Plug 'preservim/nerdtree'

" ─── Barra de estado mejorada ──────────────────────────────
Plug 'vim-airline/vim-airline'

" ─── Soporte de sintaxis JavaScript y TypeScript ───────────
Plug 'pangloss/vim-javascript'
Plug 'leafgarland/typescript-vim'

" ─── Autocompletado de paréntesis, corchetes y comillas ────
Plug 'tmsvg/pear-tree'

call plug#end()

" ═══════════════════════════════════════════════════════════
" TEMA
" ORDEN OBLIGATORIO:
"   1. set background=dark      (ya declarado arriba)
"   2. let g:gruvbox_*          (variables ANTES de colorscheme)
"   3. colorscheme gruvbox      (carga el tema al final)
" ═══════════════════════════════════════════════════════════
let g:gruvbox_contrast_dark = 'hard'   " Contraste máximo (fondo casi negro)
let g:gruvbox_italic = 0               " Evita problemas de itálicas en SSH
colorscheme gruvbox

" ═══════════════════════════════════════════════════════════
" INTERFAZ Y VISUALIZACIÓN
" ═══════════════════════════════════════════════════════════
syntax enable           " Activa los colores en la sintaxis
filetype indent plugin on

set number              " Muestra los números de línea
set mouse=a             " Activa el mouse en todos los modos
set numberwidth=1       " Ancho mínimo de la columna de números
set clipboard=unnamed   " Comparte portapapeles con el sistema
set showcmd             " Muestra el comando en ejecución
set ruler               " Muestra posición del cursor (línea, columna)
set encoding=utf-8      " Soporte para ñ y caracteres especiales
set showmatch           " Resalta paréntesis/llaves coincidentes
set showmode            " Muestra el modo actual (INSERT, NORMAL, VISUAL)
set relativenumber      " Numeración relativa al cursor
set laststatus=2        " Siempre muestra la barra de estado
set cursorline          " Resalta la línea donde está el cursor

" ═══════════════════════════════════════════════════════════
" INDENTACIÓN Y FORMATO
" ═══════════════════════════════════════════════════════════
set sw=2                " Ancho del desplazamiento (2 espacios)
set smartindent         " Indentación inteligente según contexto
set wrap                " Corta líneas largas para visualización
set bs=indent,eol,start " Backspace funciona en todo contexto

" ═══════════════════════════════════════════════════════════
" BÚSQUEDA
" ═══════════════════════════════════════════════════════════
set incsearch           " Búsqueda incremental (resalta mientras escribes)
set hlsearch            " Resalta todas las coincidencias
set ignorecase          " Ignora mayúsculas/minúsculas en búsquedas

" ═══════════════════════════════════════════════════════════
" ARCHIVOS Y RESPALDOS
" ═══════════════════════════════════════════════════════════
set undofile            " Guarda historial de cambios al cerrar
set undodir=~/.vim/undodir  " Directorio Unix (diferente a Windows)
set noswapfile          " No crea archivos .swp
set nobackup            " No crea copias de respaldo ~archivo

" ═══════════════════════════════════════════════════════════
" MODO MÁQUINA DE ESCRIBIR (Typewriter Mode)
" Cursor siempre centrado verticalmente al escribir
" ═══════════════════════════════════════════════════════════
set scrolloff=999       " Mantiene cursor centrado verticalmente
set sidescrolloff=5     " Margen horizontal mínimo

" ═══════════════════════════════════════════════════════════
" CONFIGURACIÓN DE PLUGINS
" ═══════════════════════════════════════════════════════════

" NERDTree: cierra el árbol al abrir un archivo
let NERDTreeQuitOnOpen=1

" Airline: muestra pestañas de buffers en la barra superior
let g:airline#extensions#tabline#enabled = 1
let g:airline#extensions#tabline#formatter = 'default'

" ═══════════════════════════════════════════════════════════
" LEADER Y ATAJOS DE TECLADO
" <Leader> = Barra espaciadora (igual que en Mac y Windows)
" ═══════════════════════════════════════════════════════════
let mapleader=" "

" ─── EasyMotion ────────────────────────────────────────────
" <Space>s + 2 caracteres = salta a cualquier parte del texto
nmap <Leader>s <Plug>(easymotion-s2)

" ─── NERDTree ──────────────────────────────────────────────
" <Space>nt = abre el árbol de archivos en la ubicación actual
nmap <Leader>nt :NERDTreeFind<CR>

" ─── Guardado y salida ─────────────────────────────────────
nmap <Leader>w  :w<CR>      " Guardar
nmap <Leader>q  :q<CR>      " Salir
nmap <Leader>q! :q!<CR>     " Salir sin guardar (forzado)
nmap <Leader>wq :wq<CR>     " Guardar y salir

" ─── Corrector ortográfico en español ──────────────────────
nmap <Leader>orto :setlocal spell! spelllang=es<CR>

" ─── Ejecutar Python ───────────────────────────────────────
" F5 = ejecuta el script Python abierto actualmente
" Usa python3 explícito (DSM no tiene alias 'python')
nnoremap <F5> :!python3 %:p<CR>

" ─── Atajo de escape en modo inserción ─────────────────────
" Escribir 'ii' en modo inserción equivale a presionar ESC
imap ii <ESC>
