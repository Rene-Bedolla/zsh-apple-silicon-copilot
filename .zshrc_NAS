# ═══════════════════════════════════════════════════════════
# .zshrc - SYNOLOGY NAS DS223
# Basado en configuración personal de René López
# Adaptado para DSM 7.3.2 / SynoCommunity (aarch64)
# Omite: MLX, Homebrew, Ollama, rutas macOS, multimedia local
# ═══════════════════════════════════════════════════════════

# ─── Oh My Zsh ─────────────────────────────────────────────
# Ruta de instalación (usuario ren en DSM)
export ZSH="$HOME/.oh-my-zsh"

# Tema: Powerlevel10k (igual que en Mac y Windows)
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins activos:
#   git                     → atajos y prompt de git
#   zsh-autosuggestions     → sugerencias del historial (como en Mac)
#   zsh-syntax-highlighting → resalta comandos válidos/inválidos
plugins=(git zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# ═══════════════════════════════════════════════════════════
# SISTEMA
# ═══════════════════════════════════════════════════════════

# Recarga .zshrc sin cerrar sesión SSH
# Equivalente a: source ~/.zshrc (igual que en Mac)
alias refresco='source ~/.zshrc'
alias updatezsh='source ~/.zshrc'

# Diagnóstico de red
alias pingoogle='ping 8.8.8.8'

# ═══════════════════════════════════════════════════════════
# KOHA (Catalogación - INPI)
# Acceso remoto al servidor institucional desde el NAS
# ═══════════════════════════════════════════════════════════

# Conexión SSH al servidor Koha
# Útil para administración remota desde el NAS si fuera necesario
alias conectaKoha='ssh acervos@200.57.183.23'

# ═══════════════════════════════════════════════════════════
# NAVEGACIÓN
# ═══════════════════════════════════════════════════════════

# Listados detallados con colores
alias ll='ls -laFh --color=auto'   # Lista completa con tamaños legibles
alias la='ls -A'                   # Incluye archivos ocultos
alias l='ls -CF'                   # Lista compacta en columnas

# Navegación rápida
alias ..='cd ..'
alias ...='cd ../..'
alias ~='cd ~'

# ─── Directorios frecuentes del NAS ────────────────────────
# Acceso rápido a las carpetas principales de /volume1
alias vol1='cd /volume1'
alias descargas='cd /volume1/downloads'
alias multimedia='cd /volume1/video'
alias musica='cd /volume1/music'
alias fotos='cd /volume1/photo'
alias respaldos='cd /volume1/NetBackup'

# ═══════════════════════════════════════════════════════════
# EDITORES
# vim 8.2 instalado via SynoCommunity
# ═══════════════════════════════════════════════════════════
alias vi='vim'                     # vi apunta a vim siempre

# ═══════════════════════════════════════════════════════════
# PYTHON
# DSM incluye python3 nativo en /bin/python3
# 'python' sin número no existe en DSM — este alias lo unifica
# ═══════════════════════════════════════════════════════════
alias python='python3'
alias python3='/bin/python3'
alias pip='pip3'

# ═══════════════════════════════════════════════════════════
# GIT
# Atajos equivalentes al plugin git de Oh My Zsh
# Git instalado via Package Center de SynoCommunity
# ═══════════════════════════════════════════════════════════
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'
alias gpl='git pull'
alias gl='git log --oneline --graph --decorate --all'

# ═══════════════════════════════════════════════════════════
# NAS - Administración DSM
# Comandos específicos para gestión del Synology DS223
# ═══════════════════════════════════════════════════════════

# Espacio disponible en el volumen principal (resumen limpio)
alias nas-disco='df -h | grep volume'

# Procesos activos con mayor consumo de recursos
alias nas-top='top -bn1 | head -20'

# Logs del sistema DSM en tiempo real
alias nas-log='sudo tail -f /var/log/synolog'

# Estado de servicios DSM
alias nas-status='sudo synoservicectl --list'

# Reiniciar un servicio específico
# Uso: nas-restart <nombre-servicio>
function nas-restart() {
  if [[ -z "$1" ]]; then
    echo "Uso: nas-restart <nombre-servicio>"
    echo "Ejemplo: nas-restart nginx"
    return 1
  fi
  sudo synoservicectl --restart "$1"
  echo "✅ Servicio '$1' reiniciado."
}

# ═══════════════════════════════════════════════════════════
# PATHS & ENVIRONMENT
# Rutas adaptadas para DSM (sin Homebrew ni rutas macOS)
# ═══════════════════════════════════════════════════════════
export PATH="/usr/local/bin:/usr/bin:/bin:$HOME/scripts:$HOME/.local/bin:$PATH"
export LANG=es_MX.UTF-8
export LC_ALL=es_MX.UTF-8
export TERM=xterm-256color         # Truecolor para Gruvbox en vim

# Scripts personalizados (misma convención que en Mac)
# Ubicación sugerida: ~/scripts/
# Permite ejecutar scripts propios desde cualquier directorio
export PATH="$HOME/scripts:$PATH"

# ═══════════════════════════════════════════════════════════
# POWERLEVEL10K PROMPT
# Ejecuta 'p10k configure' para personalizar el prompt
# El archivo .p10k.zsh se genera automáticamente
# ═══════════════════════════════════════════════════════════
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
