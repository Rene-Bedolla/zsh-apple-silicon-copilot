# ═══════════════════════════════════════════════════════════════════════════════
# IA LOCAL: MLX & OLLAMA
# Todos los alias comienzan con "conversar-" para fácil acceso
# Parámetros clave:
#   --temp 0.6: balance creatividad/coherencia (0=repetitivo, 1=normal, 2=aleatorio)
#   --top-p 0.9: muestreo de núcleo (0=solo mejor token, 1=todos)
# ═══════════════════════════════════════════════════════════════════════════════

# conversar (SIN SUFIJO - PRINCIPAL)
# Propósito: Conversación equilibrada general - ALIAS RECOMENDADO
# Modelo: Qwen 7B (potente, versátil) | Velocidad: 150-200 tok/seg | Respuesta: 2-3s
# Casos: investigación, teoría, explicaciones detalladas
alias conversar='mlx_lm.chat --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 1500 --temp 0.6 --top-p 0.9'

# conversar-rapido
# Propósito: Consultas rápidas para preguntas cortas/simples
# Modelo: Qwen 3B (ligero) | Velocidad: 250+ tok/seg | Respuesta: <1s
# Casos: definiciones, respuestas puntuales, consultas ligeras
alias conversar-rapido='mlx_lm.chat --model mlx-community/Qwen2.5-3B-Instruct-4bit --max-tokens 1000 --temp 0.6 --top-p 0.9'

# conversar-codigo
# Propósito: Ayuda de programación + explicación - ESPECIALIZADO PARA DESARROLLO
# Modelo: Mistral 7B (optimizado lógica/código) | Velocidad: 150+ tok/seg | Respuesta: 2-3s
# Casos: debugging, implementación, arquitectura de software, SQL
alias conversar-codigo='mlx_lm.chat --model mlx-community/Mistral-7B-Instruct-v0.3-4bit --max-tokens 2000 --temp 0.5 --top-p 0.85'

# conversar-ilimitado
# Propósito: Respuestas exhaustivas sin restricción de tokens
# Modelo: Qwen 7B | Velocidad: 150+ tok/seg | Respuesta: 5-15s
# Casos: análisis profundo, investigación completa, documentación
alias conversar-max='mlx_lm.chat --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens -1 --temp 0.6 --top-p 0.9'

# conversar-medidor
# Propósito: Muestra tokens usado + velocidad (SOLO GENERADOR, NO CHAT)
# Modelo: Qwen 7B | Output: "Generation: 487 tokens, 152.34 tokens-per-sec"
# Nota: No es interactivo, escribe prompt una sola vez
alias conversar-medidor='mlx_lm.generate --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 1500 --temp 0.6 --top-p 0.9 --verbose'
 
# conversar-creativo
# Propósito: Respuestas más creativas/diversas - para brainstorming
# Modelo: Qwen 7B (temperature más alta) | Velocidad: 150+ tok/seg | Respuesta: 2-3s
# Casos: ideación, escritura creativa, múltiples perspectivas
alias conversar-creativo='mlx_lm.chat --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 1500 --temp 0.8 --top-p 0.95'

# conversar-preciso
# Propósito: Respuestas deterministas - para tareas exactas
# Modelo: Qwen 7B (temperature baja) | Velocidad: 150+ tok/seg | Respuesta: 2-3s
# Casos: traducción, código crítico, datos exactos, información verificable
alias conversar-preciso='mlx_lm.chat --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 1500 --temp 0.3 --top-p 0.7'

# conversar-vision 
# Propósito: Análisis de imágenes - MULTIMODAL
# Modelo: Gemma 3 10B Vision | Velocidad: 100 tok/seg | RAM: 6GB
# Casos: OCR, fotos históricas, debug UI, diagramas, gráficos
# alias conversar-vision='mlx_lm.chat --model mlx-community/Gemma3-10B-Vision-Instruct-4bit --max-tokens 1500 --temp 0.6 --top-p 0.9'

# conversar-ollama
# Propósito: Fallback a Pepita 2B - comparación/alternativa
# Modelo: Pepita 2B | Velocidad: 80-100 tok/seg | Respuesta: 3-5s
# Casos: comparación con MLX, modelo ligero, pruebas
alias conversar-ollama='ollama run nichonauta/pepita-2-2b-it-v5'

# conversar-generar
# Propósito: Generación sin chat interactivo - para scripts/pipes
# Modelo: Qwen 7B | Uso: echo "Prompt" | conversar-generar
# Casos: automatización, integración en scripts, cadenas de comandos
alias conversar-generar='mlx_lm.generate --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 3000 --temp 0.6 --top-p 0.9'

# conversar-demo
# Propósito: Pruebas rápidas/ligeras - modelo ultra-ligero
# Modelo: SmolLM 1.7B | Velocidad: 300+ tok/seg | Respuesta: <1s
# Casos: pruebas de concepto, conexión rápida, demos
alias conversar-demo='mlx_lm.chat --model mlx-community/SmolLM-1.7B-Instruct --max-tokens 800 --temp 0.6 --top-p 0.9'
# MLX - Principal: 2000 tokens (respuestas completas)
alias conversar='mlx_lm.chat --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 2000'

# Ollama - Fallback
alias conversar-ollama='ollama run nichonauta/pepita-2-2b-it-v5'

# MLX - Rápido: 1000 tokens
alias mlx-rápido='mlx_lm.chat --model mlx-community/Qwen2.5-3B-Instruct-4bit --max-tokens 1000'

# MLX - Generar: 3000 tokens (muy completo para scripts)
alias mlx-generar='mlx_lm.generate --model mlx-community/Qwen2.5-7B-Instruct-4bit --max-tokens 3000'

# MLX - Código: 2000 tokens (código largo + explicación)
alias mlx-code='mlx_lm.chat --model mlx-community/Mistral-7B-Instruct-v0.3-4bit --max-tokens 2000'

# MLX - Visión: 1500 tokens (análisis detallado)
alias mlx-visión='mlx_lm.chat --model mlx-community/Llava-1.5-7B-mlx-q4 --max-tokens 1500'

# MLX - Demo: 800 tokens
alias mlx-demo='mlx_lm.chat --model mlx-community/SmolLM-1.7B-Instruct --max-tokens 800'

